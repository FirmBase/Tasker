<?xml version="1.0" encoding="UTF-8"?>
<web-app version="3.1" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd" metadata-complete="false">
	<display-name>Tasker</display-name>
	<description>
		Tasker
	</description>
	<servlet>
		<servlet-name>JSP</servlet-name>
		<servlet-class>org.apache.jasper.servlet.JspServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>JSP</servlet-name>
		<url-pattern>*.jsp</url-pattern>
	</servlet-mapping>
	<listener>
		<listener-class>com.yash.ContextListener</listener-class>
	</listener>
	<filter>
		<filter-name>RequestFilter</filter-name>
		<filter-class>com.yash.security.RequestFilter</filter-class>
		<async-supported>true</async-supported>
	</filter>
	<filter-mapping>
		<filter-name>RequestFilter</filter-name>
		<url-pattern>/*</url-pattern> <!-- intercept all incoming request -->
	</filter-mapping>
	<session-config>
		<tracking-mode>COOKIE</tracking-mode>
		<session-timeout>30</session-timeout>
		<cookie-config>
			<name>Tasker-ID</name>
			<path>/</path>
			<!-- <domain>localhost</domain> -->
			<secure>false</secure>
			<http-only>true</http-only>
		</cookie-config>
	</session-config>
	<error-page>
		<exception-type>java.lang.Exception</exception-type>
		<location>/WEB-INF/exception.jsp</location>
	</error-page>
	<error-page>
		<error-code>404</error-code>
		<location>/errors/404.html</location>
	</error-page>
	<error-page>
		<error-code>500</error-code>
		<location>/errors/500.html</location>
	</error-page>
	<resource-ref>
		<description>DB Connection</description>
		<res-ref-name>jdbc/HikariDB</res-ref-name>
		<res-type>javax.sql.DataSource</res-type>
		<res-auth>Container</res-auth>
	</resource-ref>
</web-app>
